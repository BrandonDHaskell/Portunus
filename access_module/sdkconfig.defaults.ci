# CI: build-only config — no real server, no secrets, TLS cert check disabled.
# Deployment values (host, module ID, credentials) are not set here; the CI
# build uses PORTUNUS_ENV_DEV=y so the firmware compiles without NVS provisioning.
CONFIG_PORTUNUS_USE_TLS=y
CONFIG_PORTUNUS_TLS_SKIP_VERIFY=y
CONFIG_PORTUNUS_TLS_USE_CUSTOM_CA=n
CONFIG_ESP_TLS_INSECURE=y
CONFIG_ESP_TLS_SKIP_SERVER_CERT_VERIFY=y
CONFIG_PORTUNUS_HMAC_ENABLED=n
CONFIG_PORTUNUS_ENV_DEV=y
CONFIG_PORTUNUS_DEV_MODULE_ID="ci-module"
CONFIG_PORTUNUS_DEV_WIFI_SSID="ci-net"
CONFIG_PORTUNUS_DEV_WIFI_PSK=""
CONFIG_PORTUNUS_DEV_SERVER_HOST="ci.invalid"
CONFIG_PORTUNUS_DEV_GRPC_PORT=50051

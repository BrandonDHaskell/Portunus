# DEV: points to workstation, relaxed security for rapid iteration
CONFIG_PORTUNUS_SERVER_HOST="10.0.0.59"
CONFIG_PORTUNUS_USE_TLS=y
CONFIG_PORTUNUS_TLS_SKIP_VERIFY=y
CONFIG_PORTUNUS_TLS_USE_CUSTOM_CA=y
CONFIG_ESP_TLS_INSECURE=y
CONFIG_ESP_TLS_SKIP_SERVER_CERT_VERIFY=y
CONFIG_PORTUNUS_GRPC_SERVER_PORT=50051
CONFIG_PORTUNUS_HMAC_ENABLED=n
CONFIG_PORTUNUS_MODULE_ID="door-001-dev"

# DEV: relaxed security for rapid iteration; NVS fallback credentials used when
# NVS is not provisioned (PORTUNUS_ENV_DEV=y enables the Kconfig fallback path).
CONFIG_PORTUNUS_USE_TLS=y
CONFIG_PORTUNUS_TLS_SKIP_VERIFY=y
CONFIG_PORTUNUS_TLS_USE_CUSTOM_CA=y
CONFIG_ESP_TLS_INSECURE=y
CONFIG_ESP_TLS_SKIP_SERVER_CERT_VERIFY=y
CONFIG_PORTUNUS_HMAC_ENABLED=n
CONFIG_PORTUNUS_ENV_DEV=y
CONFIG_PORTUNUS_DEV_MODULE_ID="door-001-dev"
CONFIG_PORTUNUS_DEV_WIFI_SSID="portunus-dev"
CONFIG_PORTUNUS_DEV_WIFI_PSK=""
CONFIG_PORTUNUS_DEV_SERVER_HOST="10.0.0.59"
CONFIG_PORTUNUS_DEV_GRPC_PORT=50051
